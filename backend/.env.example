# Copier en .env pour surcharger la configuration par défaut.
YOTO_DATABASE_URL=sqlite+aiosqlite:///./data/yoto_bridge.sqlite
YOTO_SYNC_INTERVAL_SECONDS=3600
YOTO_STREAM_DEFAULT_BITRATE=192
YOTO_STREAM_FORMAT=mp3
# Fenêtre anti-Range : durée pendant laquelle une même piste renvoie le même morceau.
YOTO_RESOLUTION_TTL_SECONDS=8
YOTO_CORS_ORIGINS=
# URL publique (URLs /stream déposées sur la Yoto + redirect OAuth Yoto).
# En production, remplacer par l'URL HTTPS réelle et activer OIDC.
YOTO_PUBLIC_BASE_URL=http://localhost:8000

# Authentification OIDC optionnelle (compatible Pocket ID).
YOTO_AUTH_ENABLED=false
YOTO_OIDC_ISSUER_URL=https://id.example.com
YOTO_OIDC_CLIENT_ID=
YOTO_OIDC_CLIENT_SECRET=
YOTO_OIDC_SCOPES=openid profile email
# Générer avec : openssl rand -hex 32
YOTO_SESSION_SECRET=

# Clé stable de chiffrement des secrets stockés dans SQLite.
YOTO_SECRETS_KEY=
