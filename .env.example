# Copier vers .env à côté de docker-compose.yml.
YOTO_WEB_PORT=8081

# Authentification Pocket ID / OIDC (laisser false tant que le client n'est pas prêt).
YOTO_AUTH_ENABLED=false
YOTO_OIDC_ISSUER_URL=https://id.example.com
YOTO_OIDC_CLIENT_ID=
YOTO_OIDC_CLIENT_SECRET=
YOTO_OIDC_SCOPES=openid profile email
# Générer avec : openssl rand -hex 32
YOTO_SESSION_SECRET=
