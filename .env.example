# Copier vers .env à côté de docker-compose.yml.
YOTO_WEB_PORT=8081
# En production, remplacer par l'URL HTTPS publique du bridge.
YOTO_PUBLIC_BASE_URL=http://localhost:8081
YOTO_DATA_DIR=/mnt/docker/yoto-bridge/data
# Pour une mise à jour reproductible, utiliser un tag semver ou SHA publié par GHCR.
YOTO_IMAGE_TAG=latest

# Chiffrement des secrets présents dans SQLite (Navidrome, Yoto, streaming).
# Générer une fois, sauvegarder hors du dépôt, ne jamais changer ensuite :
#   openssl rand -hex 32
YOTO_SECRETS_KEY=

# Authentification Pocket ID / OIDC (laisser false tant que le client n'est pas prêt).
YOTO_AUTH_ENABLED=false
YOTO_OIDC_ISSUER_URL=https://id.example.com
YOTO_OIDC_CLIENT_ID=
YOTO_OIDC_CLIENT_SECRET=
YOTO_OIDC_SCOPES=openid profile email
# Générer avec : openssl rand -hex 32
YOTO_SESSION_SECRET=

# Autoriser uniquement les origines connues (laisser vide = YOTO_PUBLIC_BASE_URL).
YOTO_CORS_ORIGINS=
